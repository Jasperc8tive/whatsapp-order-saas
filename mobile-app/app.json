{
  "expo": {
    "name": "WhatsOrder",
    "slug": "whatsorder-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whatsorder.mobile"
    },
    "android": {
      "package": "com.whatsorder.mobile"
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "apiBaseUrl": "https://whatsorder.app"
    }
  }
}

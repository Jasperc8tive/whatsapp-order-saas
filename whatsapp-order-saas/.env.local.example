NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Security note:
# Never commit real secrets in .env.local. Keep this file as a template only.

# Paystack — get from https://dashboard.paystack.com/#/settings/developertools
# Use sk_test_... during development and sk_live_... in production
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL used in payment callback links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI — used for AI order capture parsing
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# WhatsApp Cloud API — set up at https://developers.facebook.com/apps/
# 1. Create a Meta App → Add WhatsApp product
# 2. Generate a permanent system user access token
# 3. Copy the Phone Number ID from the WhatsApp dashboard
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_API_VERSION=v19.0

# WhatsApp webhook verification
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-random-verify-token
WHATSAPP_APP_SECRET=replace-with-meta-app-secret

# Worker authentication (used by scripts/run-worker.js -> /api/jobs/worker)
WORKER_SECRET=replace-with-random-worker-secret
